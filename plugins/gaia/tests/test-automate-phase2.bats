    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  # A file written to disk proves main (non-fork) context access.
  [ "$status" -eq 0 ]
  [ -f "$test_file" ]
  [[ "$output" != *"context: fork"* ]]
  [[ "$output" != *"fork subagent"* ]]
}

# ---------------------------------------------------------------------------
# AC8 — Phase 2 complete → plan phase=executed + story Review Gate + sprint
# [FR-TAF-1]
# ---------------------------------------------------------------------------

@test "AC8: phase2_complete_plan_phase_executed_story_sprint_updated" {
  local story_key="E35-S3-AC8"
  local plan_id="plan-$(date +%s)-ac8"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/gaia-public/plugins/gaia/tests/fixtures/test-automate-phase2/ac8"
  local source_file="$TEST_TMP/src/ac8-widget.sh"
  local test_file="$allowlist_dir/ac8-widget.test.bats"
  local story_artifact="$TEST_TMP/docs/implementation-artifacts/${story_key}-fake.md"

  mkdir -p "$allowlist_dir" "$(dirname "$source_file")"
  printf '#!/usr/bin/env bash\nac8() { echo ac8; }\n' > "$source_file"
  local sha
  sha="$(sha256_of "$source_file")"

  local sources_json='[{"path":"'"$source_file"'","sha256":"'"$sha"'"}]'
  local tests_json='[{"test_file":"'"$test_file"'","test_cases":[{"name":"ac8 test","assertion":"output equals ac8"}]}]'

  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "$sources_json" "$tests_json"
  make_test_env "$test_env_path" "$allowlist_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"
  seed_story_artifact "$story_artifact" "$story_key"

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -eq 0 ]

  # Plan file phase updated to "executed".
  grep -q 'phase: executed' "$plan_path" || grep -q '"phase":"executed"' "$plan_path"

  # Plan file contains execution_summary block.
  grep -qi 'execution_summary' "$plan_path"

  # Story Review Gate row for Test Automation updated to PASSED.
  grep -q 'Test Automation | PASSED' "$story_artifact"
}

# ---------------------------------------------------------------------------
# AC9 — V1 regression fixture → new test files written and executed
# [TC-TAF-7]
# ---------------------------------------------------------------------------

@test "AC9: v1_regression_fixture_test_files_written_and_executed" {
  local story_key="E35-S3-AC9"
  local plan_id="plan-v1-parity-$(date +%s)"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local fixture_dir="$TEST_TMP/gaia-public/plugins/gaia/tests/fixtures/test-automate-phase2/v1-parity"
  local source_file="$fixture_dir/legacy-feature.sh"
  local test_file="$fixture_dir/legacy-feature.test.bats"
  local evidence_path="$TEST_TMP/docs/test-artifacts/test-results/${story_key}-execution.json"

  mkdir -p "$fixture_dir" "$(dirname "$evidence_path")"

  cat > "$source_file" <<'SHELL'
#!/usr/bin/env bash
# Legacy V1 feature — must be tested by Phase 2 regression suite.
legacy_compute() { echo "$(( $1 + $2 ))"; }
SHELL

  local sha
  sha="$(sha256_of "$source_file")"

  local sources_json='[{"path":"'"$source_file"'","sha256":"'"$sha"'"}]'
  local tests_json='[{"test_file":"'"$test_file"'","test_cases":[{"name":"legacy_compute adds two numbers","assertion":"legacy_compute 3 4 equals 7"}]}]'

  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "$sources_json" "$tests_json"
  make_test_env "$test_env_path" "$fixture_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -eq 0 ]
  [ -f "$test_file" ]
  [ -f "$evidence_path" ]
  grep -q '"executed"' "$evidence_path" || grep -q '"tests_run"' "$evidence_path"
}

