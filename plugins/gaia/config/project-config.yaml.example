# project-config.yaml.example — annotated example for GAIA Native per-project config
#
# Realizes ADR-044 (config split). This file is the canonical smoke-test input
# for resolve-config.sh (E28-S9) — CI (E28-S7) resolves this example on every
# PR and fails if it drifts out of schema declared in project-config.schema.yaml.
#
# Every field in project-config.schema.yaml appears below with a representative
# value, inline comment, and ADR cross-reference where relevant.
#
# To use: copy this file to project-config.yaml at your plugin's config/ root
# and adjust values for your project.

# Absolute path to the framework root (where _gaia/ lives).
# Required. No default.
project_root: /Users/you/Dev/my-project

# Absolute path to the application source tree. Pinning this to a non-"."
# subpath makes the framework/project split visible (ADR-044). Required.
project_path: /Users/you/Dev/my-project/my-app

# Absolute path to persistent agent memory directory.
# Required. Typically <project_root>/_memory.
memory_path: /Users/you/Dev/my-project/_memory

# Absolute path to workflow checkpoint directory.
# Required. Typically <memory_path>/checkpoints.
checkpoint_path: /Users/you/Dev/my-project/_memory/checkpoints

# Absolute path to the installed framework tree (_gaia/). Required.
installed_path: /Users/you/Dev/my-project/_gaia

# GAIA framework version this project targets — pinned per project so
# upgrades are deliberate. Required.
framework_version: 1.127.2-rc.1

# ISO-8601 date stamp for this config revision. Required.
date: 2026-04-15

# Artifact paths — relative to project_root (E60-S1 / ADR-074 contract C1).
# Optional. Resolver composes absolute paths at call time; do NOT prepend
# ${project_root}/. Defaults shown below match the framework layout.
planning_artifacts: docs/planning-artifacts
implementation_artifacts: docs/implementation-artifacts
test_artifacts: docs/test-artifacts
creative_artifacts: docs/creative-artifacts

# Val integration — template-output review gates. See ADR-042.
# Optional. Default: { template_output_review: true }
val_integration:
  template_output_review: true

# CI/CD promotion chain — ordered list of environments. See ADR-048.
# Optional. Written by /gaia-ci-setup.
ci_cd:
  promotion_chain:
    - id: staging
      name: Staging
      branch: staging
      ci_provider: github_actions
      merge_strategy: merge
      ci_checks:
        - lint
        - unit
        - test
    - id: main
      name: main
      branch: main
      ci_provider: github_actions
      merge_strategy: squash

# Testing integration — framework, bridge, and coverage thresholds.
# Optional.
testing:
  framework: bats
  bridge_enabled: false
  coverage_threshold: 80

# Dev-Story workflow knobs (E57-S1). Configures the post-Red TDD review
# gate consumed by /gaia-dev-story. Optional — defaults shown below.
#
# threshold (enum off|low|medium|high; default medium):
#   risk threshold at which the post-Red review gate prompt fires.
#   Set to 'off' to opt out entirely.
# phases (array; default [red]):
#   TDD phase(s) at which the review fires.
# qa_auto_in_yolo (bool; default true):
#   whether YOLO mode auto-runs the QA review after the gate.
# qa_timeout_seconds (int; default 600):
#   per-review timeout for the QA auto-run.
dev_story:
  tdd_review:
    threshold: medium
    phases: [red]
    qa_auto_in_yolo: true
    qa_timeout_seconds: 600
