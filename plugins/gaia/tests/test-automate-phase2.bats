# ---------------------------------------------------------------------------
# AC-EC10 — Target test file already exists → HALT to prevent clobbering
# [error]
# ---------------------------------------------------------------------------

@test "AC-EC10: edge_target_test_file_already_exists_halt" {
  local story_key="E35-S3-EC10"
  local plan_id="plan-$(date +%s)-ec10"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/gaia-public/plugins/gaia/tests/fixtures/test-automate-phase2/ec10"
  local test_file="$allowlist_dir/existing.test.bats"

  mkdir -p "$allowlist_dir"
  # Pre-create the test file — user work that must not be clobbered.
  printf '#!/usr/bin/env bats\n@test "pre-existing user test" { true; }\n' > "$test_file"

  local tests_json='[{"test_file":"'"$test_file"'","test_cases":[{"name":"new test","assertion":"true"}]}]'

  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "[]" "$tests_json"
  make_test_env "$test_env_path" "$allowlist_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"

  local original_content
  original_content="$(cat "$test_file")"

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -ne 0 ]
  [[ "$output" == *"already exists"* ]] || [[ "$output" == *"clobber"* ]]

  # Original file content must be preserved — no clobbering occurred.
  local current_content
  current_content="$(cat "$test_file")"
  [ "$current_content" = "$original_content" ]
}
