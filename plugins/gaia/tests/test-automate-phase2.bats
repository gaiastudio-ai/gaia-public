# ---------------------------------------------------------------------------
# AC-EC2 — Empty proposed_tests[] → zero files written; evidence 0 cases
# [boundary]
# ---------------------------------------------------------------------------

@test "AC-EC2: edge_empty_proposed_tests_zero_files_written" {
  local story_key="E35-S3-EC2"
  local plan_id="plan-$(date +%s)-ec2"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/gaia-public/plugins/gaia/tests/fixtures/test-automate-phase2/ec2"
  local evidence_path="$TEST_TMP/docs/test-artifacts/test-results/${story_key}-execution.json"

  mkdir -p "$allowlist_dir" "$(dirname "$evidence_path")"

  # proposed_tests is intentionally empty.
  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "[]" "[]"
  make_test_env "$test_env_path" "$allowlist_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -eq 0 ]
  local file_count
  file_count="$(find "$allowlist_dir" -type f 2>/dev/null | wc -l | tr -d ' ')"
  [ "$file_count" -eq 0 ]
  [ -f "$evidence_path" ]
  grep -q '"tests_run":0' "$evidence_path" || \
    grep -q '"test_count":0' "$evidence_path" || \
    grep -q '"cases":\[\]' "$evidence_path"
}

# ---------------------------------------------------------------------------
# AC-EC3 — Plan file missing → HALT "plan file not found at {path}"; no writes
# [error]
# ---------------------------------------------------------------------------

@test "AC-EC3: edge_plan_file_missing_halt_not_found" {
  local story_key="E35-S3-EC3"
  local plan_path="$TEST_TMP/does-not-exist/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/allowed"

  mkdir -p "$allowlist_dir"
  make_test_env "$test_env_path" "$allowlist_dir"
  # Plan file deliberately not created.

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -ne 0 ]
  [[ "$output" == *"plan file not found"* ]] || [[ "$output" == *"not found"* ]]
  [[ "$output" == *"$plan_path"* ]]
  [ ! -f "$TEST_TMP/docs/test-artifacts/test-results/${story_key}-execution.json" ]
}

# ---------------------------------------------------------------------------
# AC-EC4 — Malformed YAML frontmatter → HALT plan_tamper_detected; no writes
# [data]
# ---------------------------------------------------------------------------

@test "AC-EC4: edge_malformed_yaml_frontmatter_halt_plan_tamper_detected" {
  local story_key="E35-S3-EC4"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/allowed"
  local plan_id="plan-$(date +%s)-ec4"

  mkdir -p "$allowlist_dir" "$(dirname "$plan_path")"
  make_test_env "$test_env_path" "$allowlist_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"

  # Write intentionally broken YAML frontmatter.
  cat > "$plan_path" <<'BROKEN'
---
template: test-automate-plan
plan_id: "unclosed-string
approval:
  verdict: PASSED
  verdict_plan_id: [invalid: yaml: here
analyzed_sources: NOT_AN_ARRAY
---

# Broken plan
BROKEN

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -ne 0 ]
  [[ "$output" == *"plan_tamper_detected"* ]]
  [ ! -f "$TEST_TMP/docs/test-artifacts/test-results/${story_key}-execution.json" ]
}

# ---------------------------------------------------------------------------
# AC-EC5 — Path traversal in proposed_tests[].test_file → HALT out_of_scope
# [security]
# ---------------------------------------------------------------------------

@test "AC-EC5: edge_path_traversal_in_proposed_test_file_halts" {
  local story_key="E35-S3-EC5"
  local plan_id="plan-$(date +%s)-ec5"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/gaia-public/plugins/gaia/tests"

  mkdir -p "$allowlist_dir"

  # Path uses ../ traversal to escape the allowlist boundary.
  local traversal_path="$allowlist_dir/../../../etc/passwd.test.js"

  local tests_json='[{"test_file":"'"$traversal_path"'","test_cases":[]}]'

  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "[]" "$tests_json"
  make_test_env "$test_env_path" "$allowlist_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -ne 0 ]
  [[ "$output" == *"target_path_out_of_scope"* ]]
  # The resolved canonical path of the traversal target must not have been written.
  [ ! -f "/etc/passwd.test.js" ]
  [ ! -f "$TEST_TMP/docs/test-artifacts/test-results/${story_key}-execution.json" ]
}

# ---------------------------------------------------------------------------
# AC-EC6 — test-environment.yaml missing → HALT; no fallback allowlist
# [environment]
# ---------------------------------------------------------------------------

@test "AC-EC6: edge_test_environment_yaml_missing_halt_no_fallback" {
  local story_key="E35-S3-EC6"
  local plan_id="plan-$(date +%s)-ec6"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  # Point at a test-environment.yaml that does NOT exist.
  local test_env_path="$TEST_TMP/does-not-exist/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/tests"

  mkdir -p "$allowlist_dir"
  local test_file="$allowlist_dir/ec6.test.bats"
  local tests_json='[{"test_file":"'"$test_file"'","test_cases":[{"name":"ec6","assertion":"true"}]}]'

  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "[]" "$tests_json"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"
  # Deliberately do NOT create test-environment.yaml.

  run "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  [ "$status" -ne 0 ]
  [[ "$output" == *"test-environment"* ]] || [[ "$output" == *"missing"* ]]
  [ ! -f "$test_file" ]
}

# ---------------------------------------------------------------------------
# AC-EC7 — Source modified DURING Phase 2 (documented limitation — skipped)
# [concurrency — documented, not coded]
# ---------------------------------------------------------------------------

# @todo FR-TAF-CONCURRENCY: Documented known limitation.
# Phase 2 drift-checks at Step 1 and invokes the Bridge at Step 4.
# A source file modified between these two steps is undetected.
# The Bridge executes against the modified filesystem.
# When a mid-phase detection mechanism is added, update this test to assert
# HALT status: mid_phase_drift.
@test "AC-EC7: edge_source_modified_during_phase2_documented_limitation" {
  skip "Known limitation: concurrent modification between drift-check (Step 1) and Bridge invocation (Step 4) is not detected. Bridge executes against current filesystem. See ADR-028 known limitations and FR-TAF-CONCURRENCY."
}

# ---------------------------------------------------------------------------
# AC-EC8 — Bridge unavailable → test files written; bridge-failure annotation;
#           plan phase=executed
# [integration]
# ---------------------------------------------------------------------------

@test "AC-EC8: edge_bridge_unavailable_files_written_annotation_added" {
  local story_key="E35-S3-EC8"
  local plan_id="plan-$(date +%s)-ec8"
  local plan_path="$TEST_TMP/docs/test-artifacts/plans/${story_key}-plan.md"
  local ledger_path="$TEST_TMP/.review-gate-ledger"
  local test_env_path="$TEST_TMP/test-environment.yaml"
  local allowlist_dir="$TEST_TMP/gaia-public/plugins/gaia/tests/fixtures/test-automate-phase2/ec8"
  local source_file="$TEST_TMP/src/ec8-widget.sh"
  local test_file="$allowlist_dir/ec8-widget.test.bats"
  local evidence_path="$TEST_TMP/docs/test-artifacts/test-results/${story_key}-execution.json"

  mkdir -p "$allowlist_dir" "$(dirname "$source_file")" "$(dirname "$evidence_path")"
  printf '#!/usr/bin/env bash\nec8_widget() { echo ec8; }\n' > "$source_file"
  local sha
  sha="$(sha256_of "$source_file")"

  local sources_json='[{"path":"'"$source_file"'","sha256":"'"$sha"'"}]'
  local tests_json='[{"test_file":"'"$test_file"'","test_cases":[{"name":"ec8 test","assertion":"output equals ec8"}]}]'

  make_plan_file "$plan_path" "$story_key" "$plan_id" "PASSED" "$plan_id" \
    "$sources_json" "$tests_json"
  make_test_env "$test_env_path" "$allowlist_dir"
  seed_ledger "$ledger_path" "$story_key" "$plan_id" "PASSED"

  # Stub PATH: only a minimal stub dir with no bridge binary.
  local stub_bin_dir="$TEST_TMP/stub-bin"
  mkdir -p "$stub_bin_dir"

  run env PATH="$stub_bin_dir" "$PHASE2_ENTRYPOINT" \
    --story "$story_key" \
    --plan "$plan_path" \
    --ledger "$ledger_path" \
    --test-env "$test_env_path" \
    --project-root "$TEST_TMP"

  # Test file must still be written despite bridge failure.
  [ -f "$test_file" ]

  # Evidence file produced with bridge_failure annotation.
  [ -f "$evidence_path" ]
  grep -qi 'bridge.failure\|bridge_failure\|bridge_unavailable' "$evidence_path"

  # Plan phase still set to executed.
  grep -q 'phase: executed' "$plan_path" || grep -q '"phase":"executed"' "$plan_path"
}

